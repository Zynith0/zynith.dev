---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Zynith - Projects">
  <main>
    <div class="project">
      <a href="https://github.com/Zynith0/Gopher">
        <h2 class="project-header">Gopher</h2>
      </a>
      <p class="project-desc">Gopher is a tool to add the missing features to the go command. It adds things such as an init command.</p>
    </div>
    <div class="project">
      <a href="https://github.com/Zynith0/wildberry.nvim">
        <h2 class="project-header">wildberry.nvim</h2>
      </a>
      <p class="project-desc">Wildberry is a neovim colorscheme with a very blue, red, and purple theme</p>
    </div>
    <div class="project">
      <a href="https://github.com/Zynith0/emeraldstone.nvim">
        <h2 class="project-header">emeraldstone.nvim</h2>
      </a>
      <p class="project-desc">Emeraldstone is a neovim colorscheme with dark green, gray, and blue themes</p>
    </div>
  </main>
</Layout>

<style>
  @keyframes slide-in {
    from {
      transform: translateY(100%);
      opacity: 0
    }
    80% {
      transform: translateY(-2%);
      opacity: 1
    }
    to {
      transform: translateY(0%);
      opacity: 1
    }
  }

  * {
	font-size: 20px;
  }

  main {
    padding-top: 80px;
    padding-left: 24px;
    padding-right: 24px;
  }

  .project-header {
    color: #d3c6aa;
    font-weight: bold;
  }

  .project-desc {
    color: #9da9a0;
    font-weight: bold;
  }

  .project-img {
    width: 915px;
    height: 234px;
  }

  .project {
    animation: slide-in 0.6s;
    margin-bottom: 32px;
  }
</style>
