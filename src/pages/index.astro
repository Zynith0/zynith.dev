---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Zynith">
<main>
    <h1 id="greeting">Hello!</h1>
    <div id="main-content">
        <img
            alt="an upclose of kasane teto's face"
            src="https://i.pinimg.com/736x/d0/56/55/d056558849322f6088c31784cd58fe9f.jpg"
            id="teto"
        />
        <p class="text" id="desc">
            My name is <span style="color: #83c092;">Zynith.</span><br />
            I am a transfem (mainly) backend dev<br />
        </p>
        <button
            id="more-about-me"
            class="main-button"
			onclick="window.open('/zynith.dev/about', '_self')">More about me</button
        >
        <button
            class="main-button"
            onclick="window.open('/zynith.dev/projects', '_self')">Projects</button
        >
    </div>
</main>

<style>
    main {
        padding-top: 60px;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
    }

    #greeting {
        color: #d3c6aa;
        text-align: center;
        font-weight: bold;
        margin: 0;
        font-size: 48px;
    }

    #main-content {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 20px;
        margin-top: 32px;
    }

    #teto {
        width: 100%;
        max-width: 400px;
        height: auto;
        aspect-ratio: 1 / 1;
        object-fit: cover;
        border: 3px solid #e67e80;
        animation: slide-in-rotate 0.6s;
    }

    .main-button {
        outline: none;
        background-color: transparent;
        border: 2px solid #83c092;
        color: #d3c6aa;
        height: 25px;
        transition: all 0.2s ease-in-out;
        animation: slide-in 0.6s;
    }

    .main-button:hover {
        cursor: pointer;
        background-color: #56635f;
    }

    .text {
        color: #d3c6aa;
        font-weight: bold;
        font-size: 18px;
        text-align: center;
        animation: slide-in 0.6s;
    }

    @media (max-width: 600px) {
        main {
            padding-top: 80px;
            justify-content: flex-start;
        }

        #greeting {
            font-size: 32px;
        }

        #teto {
            max-width: 280px;
        }

        .text {
            font-size: 16px;
            padding: 0 16px;
        }
    }
</style>
